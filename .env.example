# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ─── Database (Neon Postgres) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Clerk Authentication ────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk redirect URLs (defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────
# Get these from https://developers.facebook.com → your WhatsApp app
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ─── Vapi (AI Voice Calls) ───────────────────────────────────────
# Get these from https://dashboard.vapi.ai
# Server-side key for backend API calls (private key)
# Optional alias supported by this app: VAPI_PRIVATE_KEY
# Do NOT use your Vapi public/browser key here.
VAPI_API_KEY=your_vapi_private_key_here
# Recommended: use a saved assistant from Vapi Dashboard to avoid transient payload validation issues
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# Optional: used when lead phone is stored as 10 digits (e.g., 619787xxxx)
# Default is 1 (US/Canada)
VAPI_DEFAULT_COUNTRY_CODE=1

# Webhook secret — set this in Vapi dashboard under Server URL settings
# Generate with: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=your_random_webhook_secret_here


